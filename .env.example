# ============================================================
# INSTEP-WFU Advisor — Environment Variables
# Copy this file to `.env` and fill in your values.
# NEVER commit `.env` to a public git repository.
# ============================================================

# Which LLM to use: perplexity | openai | anthropic
LLM_PROVIDER=perplexity

# Server port
PORT=8787

# Comma-separated list of origins allowed to call this proxy.
# For local testing you can leave as *; for production use your real domain(s).
# Example: ALLOWED_ORIGINS=https://www.instep-programs.org,https://instep-programs.org
ALLOWED_ORIGINS=*

# ----- Provider API keys (only fill in the one you're using) -----

# Perplexity — get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
